{
    "version": 2,
    "builds": [
        {
            "src": "app.py",
            "use": "@vercel/python",
            "config": {
                "runtime": "python3.9",
                "includeFiles": [
                    "shappno.txt",
                    "like_pb2.py",
                    "like_count_pb2.py",
                    "uid_generator_pb2.py"
                ]
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "app.py"
        }
    ]
}